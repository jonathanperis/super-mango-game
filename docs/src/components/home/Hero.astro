<!-- Floating particles -->
<div class="particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
</div>

<!-- Parallax hero -->
<section class="hero" id="hero">
    <div class="parallax-layer sky-layer"></div>
    <div class="parallax-layer mountains-layer"></div>
    <div class="parallax-layer trees-far-layer"></div>
    <div class="parallax-layer trees-near-layer"></div>
    <div class="parallax-layer ground-layer"></div>
    <div class="hero-content">
        <div class="hero-badge">C11 &middot; SDL2 &middot; WebAssembly</div>
        <h1 class="hero-title">
            <span class="shimmer-text">
                SUPER<br />MANGO
            </span>
        </h1>
        <p class="hero-sub">A 2D pixel art platformer. Play in your browser.</p>
        <div class="hero-ctas">
            <a href="#play" class="btn-play">&#9654; PLAY NOW</a>
            <a href="#downloads" class="btn-download">&darr; DOWNLOAD</a>
        </div>
    </div>
    <div class="scroll-hint">SCROLL &darr;</div>
</section>
