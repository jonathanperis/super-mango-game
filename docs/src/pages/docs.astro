---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageIsland from "@/components/docs/DocPageIsland";
import HomeSection from "@/components/docs/sections/HomeSection.astro";
import ArchitectureSection from "@/components/docs/sections/ArchitectureSection.astro";
import AssetsSection from "@/components/docs/sections/AssetsSection.astro";
import BuildSystemSection from "@/components/docs/sections/BuildSystemSection.astro";
import ConstantsSection from "@/components/docs/sections/ConstantsSection.astro";
import DeveloperGuideSection from "@/components/docs/sections/DeveloperGuideSection.astro";
import PlayerModuleSection from "@/components/docs/sections/PlayerModuleSection.astro";
import SoundsSection from "@/components/docs/sections/SoundsSection.astro";
import SourceFilesSection from "@/components/docs/sections/SourceFilesSection.astro";
---

<BaseLayout title="Documentation - Super Mango Editor">
    <div class="docs-layout">
        <!-- Interactive island: sidebar + search + scrollspy -->
        <DocPageIsland client:load />

        <!-- Static content: all doc sections rendered as plain HTML -->
        <div class="content-wrapper">
            <main class="content" id="mainContent">
                <HomeSection />
                <ArchitectureSection />
                <AssetsSection />
                <BuildSystemSection />
                <ConstantsSection />
                <DeveloperGuideSection />
                <PlayerModuleSection />
                <SoundsSection />
                <SourceFilesSection />
            </main>
        </div>
    </div>
</BaseLayout>
