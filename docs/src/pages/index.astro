---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/home/Hero.astro";
import Nav from "@/components/home/Nav.astro";
import PlaySection from "@/components/home/PlaySection";
import AboutSection from "@/components/home/AboutSection.astro";
import DocsSection from "@/components/home/DocsSection.astro";
import DownloadsSection from "@/components/home/DownloadsSection.astro";
import Footer from "@/components/home/Footer.astro";
---

<BaseLayout>
    <Hero />
    <Nav />
    <PlaySection client:visible />
    <AboutSection />
    <DocsSection />
    <DownloadsSection />
    <Footer />
</BaseLayout>

<script>
    /* Parallax scroll: set --scroll CSS variable used by parallax layers */
    window.addEventListener("scroll", () => {
        document.documentElement.style.setProperty("--scroll", String(window.scrollY));
    });

    /* Nav visibility: show sticky nav when hero scrolls out of view */
    const hero = document.getElementById("hero");
    const nav = document.getElementById("site-nav");

    if (hero && nav) {
        const observer = new IntersectionObserver(([entry]) => {
            nav.classList.toggle("visible", !entry.isIntersecting);
        });
        observer.observe(hero);
    }
</script>
